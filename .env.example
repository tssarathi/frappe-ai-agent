# Server
AI_AGENT_HOST=0.0.0.0
AI_AGENT_PORT=8484
AI_AGENT_WORKERS=4
AI_AGENT_CORS_ORIGINS=["http://localhost:8080"]

# Auth
AI_AGENT_JWT_SECRET=change-me-to-a-random-secret

# LLM
AI_AGENT_LLM_PROVIDER=openai
AI_AGENT_LLM_BASE_URL=http://localhost:11434/v1
# When using Ollama (AI_AGENT_LLM_PROVIDER=openai pointing at localhost:11434),
# AI_AGENT_LLM_API_KEY must be non-empty. Use any string, e.g. "ollama".
# For real OpenAI/Anthropic, set your actual API key here.
AI_AGENT_LLM_API_KEY=
AI_AGENT_LLM_MODEL=llama3.2:3b
AI_AGENT_LLM_TEMPERATURE=0.7
AI_AGENT_LLM_MAX_TOKENS=4096

# MCP
# Note: the MCP protocol endpoint is port 8081 (not 8080 which is the legacy REST API)
AI_AGENT_MCP_SERVER_URL=http://localhost:8081/mcp

# PostgreSQL
AI_AGENT_DATABASE_URL=postgresql+asyncpg://copilot:copilot@localhost:5432/copilot

# Redis
AI_AGENT_REDIS_URL=redis://localhost:6379/0

# Rate Limiting
AI_AGENT_RATE_LIMIT_REQUESTS=60
AI_AGENT_RATE_LIMIT_WINDOW_SECONDS=60

# Observability
AI_AGENT_OTEL_ENDPOINT=
AI_AGENT_OTEL_SERVICE_NAME=copilot-agent
AI_AGENT_LOG_LEVEL=info
AI_AGENT_LOG_FORMAT=json
