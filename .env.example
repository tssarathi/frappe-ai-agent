# Server
COPILOT_HOST=0.0.0.0
COPILOT_PORT=8484
COPILOT_WORKERS=4
COPILOT_CORS_ORIGINS=["http://localhost:8080"]

# Auth
COPILOT_JWT_SECRET=change-me-to-a-random-secret

# LLM
COPILOT_LLM_PROVIDER=openai
COPILOT_LLM_BASE_URL=http://localhost:11434/v1
# When using Ollama (COPILOT_LLM_PROVIDER=openai pointing at localhost:11434),
# COPILOT_LLM_API_KEY must be non-empty. Use any string, e.g. "ollama".
# For real OpenAI/Anthropic, set your actual API key here.
COPILOT_LLM_API_KEY=
COPILOT_LLM_MODEL=llama3.2:3b
COPILOT_LLM_TEMPERATURE=0.7
COPILOT_LLM_MAX_TOKENS=4096

# MCP
# Note: the MCP protocol endpoint is port 8081 (not 8080 which is the legacy REST API)
COPILOT_MCP_SERVER_URL=http://localhost:8081/mcp

# PostgreSQL
COPILOT_DATABASE_URL=postgresql+asyncpg://copilot:copilot@localhost:5432/copilot

# Redis
COPILOT_REDIS_URL=redis://localhost:6379/0

# Rate Limiting
COPILOT_RATE_LIMIT_REQUESTS=60
COPILOT_RATE_LIMIT_WINDOW_SECONDS=60

# Observability
COPILOT_OTEL_ENDPOINT=
COPILOT_OTEL_SERVICE_NAME=copilot-agent
COPILOT_LOG_LEVEL=info
COPILOT_LOG_FORMAT=json
